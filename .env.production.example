APP_NAME="PlastiGest"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.tu-dominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

# Worker: 1 proceso por CPU, reintentos 3, backoff exponencial
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logs: stack -> daily (un archivo por día, 14 días de retención)
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Base de datos de producción (MySQL gestionado, NO localhost)
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Sanctum: tokens sin expiración + dominios stateful para web
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=database

CACHE_STORE=redis

# Redis (recomendado en prod: cache + queue + session)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail transaccional: configura tu proveedor real
# Opciones: smtp, mailgun, ses, postmark, resend
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@tu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# URL pública del frontend (para CORS y links en emails)
FRONTEND_URL=https://app.tu-dominio.com

# Sanctum: lista de dominios que pueden mantener sesión por cookie
# (web solamente, separado por comas)
SANCTUM_STATEFUL_DOMAINS=app.tu-dominio.com,localhost:3000

# Firebase (notificaciones push)
# IMPORTANTE: este archivo NO debe commitearse el service-account.json
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json

# Almacenamiento (S3 recomendado para prod, no local)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
